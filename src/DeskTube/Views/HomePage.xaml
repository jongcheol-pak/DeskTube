<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DeskTube.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrls="using:DeskTube.Controls"
    xmlns:vm="using:DeskTube.ViewModels">
    <!-- 시안 홈: 제목/부제 → URL 입력+재생 → 재생 중 pill → 모니터 카드 → (하단) 빠른 재생.
         시안이 overflow:auto + 빠른 재생 하단 정렬(margin-top:auto)이라 ScrollViewer 안 Grid의
         MinHeight를 뷰포트에 맞춰(코드비하인드) 둘 다 재현한다. -->
    <ScrollViewer x:Name="Root" SizeChanged="OnRootSizeChanged">
        <Grid x:Name="Layout" Padding="{StaticResource AppPagePadding}" RowSpacing="36">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 제목 + 부제 (시안 30px/14px) -->
            <StackPanel Grid.Row="0" Spacing="8">
                <TextBlock
                    x:Uid="HomeHeader"
                    FontSize="30"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource AppTextStrongBrush}" />
                <TextBlock
                    x:Uid="HomeSubtitle"
                    FontSize="14"
                    Foreground="{ThemeResource AppTextSecondaryBrush}" />
            </StackPanel>

            <!-- URL 입력 + 재생 버튼 (시안 h48, max 860, gap 12) -->
            <Grid Grid.Row="1" MaxWidth="860" HorizontalAlignment="Left" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!-- WinUI TextBox 템플릿은 VerticalContentAlignment를 무시하므로 세로 패딩으로 중앙 정렬 -->
                <TextBox
                    x:Uid="HomeUrlBox"
                    x:Name="UrlBox"
                    Grid.Column="0"
                    Height="48"
                    MinWidth="480"
                    Padding="18,13"
                    Background="{ThemeResource AppInputBackgroundBrush}"
                    BorderBrush="{ThemeResource AppInputBorderBrush}"
                    CornerRadius="{StaticResource AppCardCornerRadius}"
                    Text="{x:Bind ViewModel.Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    KeyDown="OnUrlBoxKeyDown" />
                <Button
                    Grid.Column="1"
                    Height="48"
                    Padding="26,0"
                    Style="{StaticResource AccentButtonStyle}"
                    CornerRadius="{StaticResource AppCardCornerRadius}"
                    Command="{x:Bind ViewModel.PlayCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE768;" FontSize="14" />
                        <TextBlock x:Uid="HomePlayLabel" FontSize="14" FontWeight="SemiBold" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- 재생 중 pill (시안 — 코럴 dot + 라벨 + 정지 버튼, 재생 중에만) -->
            <Border
                Grid.Row="2"
                Visibility="{x:Bind ViewModel.IsPlaying, Mode=OneWay}"
                Background="{ThemeResource AppTintBackgroundBrush}"
                BorderBrush="{ThemeResource AppTintBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource AppPillCornerRadius}"
                Padding="18,8,8,8"
                HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{ThemeResource AppAccentBrush}" VerticalAlignment="Center" />
                    <TextBlock
                        Text="{x:Bind ViewModel.PlayingLabel, Mode=OneWay}"
                        FontSize="13"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource AppTintTextBrush}" />
                    <Button
                        Padding="14,5"
                        Background="{ThemeResource AppTintButtonBackgroundBrush}"
                        BorderThickness="0"
                        CornerRadius="{StaticResource AppStopButtonCornerRadius}"
                        Command="{x:Bind ViewModel.StopCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE71A;" FontSize="11" Foreground="{ThemeResource AppTintButtonTextBrush}" />
                            <TextBlock
                                x:Uid="HomeStopLabel"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource AppTintButtonTextBrush}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- 재생 모니터 (시안 — 대형 카드, 클릭 토글) -->
            <StackPanel Grid.Row="3" Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock
                        x:Uid="HomeMonitorsTitle"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource AppTextPrimaryBrush}" />
                    <TextBlock
                        x:Uid="HomeMonitorsHint"
                        FontSize="13"
                        VerticalAlignment="Bottom"
                        Foreground="{ThemeResource AppTextTertiaryBrush}" />
                </StackPanel>
                <ctrls:MonitorCardsControl Monitors="{x:Bind ViewModel.MonitorPanel.Monitors}" IsLarge="True" />
            </StackPanel>

            <!-- 안내 InfoBar (URL 오류·재생 실패 등 — 기존 기능 유지) -->
            <InfoBar
                Grid.Row="4"
                VerticalAlignment="Top"
                IsOpen="{x:Bind ViewModel.IsNoticeOpen, Mode=TwoWay}"
                Message="{x:Bind ViewModel.NoticeMessage, Mode=OneWay}"
                Severity="{x:Bind ViewModel.NoticeSeverity, Mode=OneWay}" />

            <!-- 빠른 재생 칩 (시안 — 페이지 하단 정렬, 리스트 없으면 섹션 숨김) -->
            <StackPanel
                Grid.Row="5"
                Spacing="12"
                Visibility="{x:Bind ViewModel.HasChips, Mode=OneWay}">
                <TextBlock
                    x:Uid="HomeQuickPlayTitle"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource AppTextPrimaryBrush}" />
                <ItemsControl ItemsSource="{x:Bind ViewModel.QuickChips}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VariableSizedWrapGrid Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:QuickChip">
                            <Button
                                Style="{StaticResource AppChipButtonStyle}"
                                Margin="0,0,12,12"
                                Click="OnChipClick">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE8FD;" FontSize="13" />
                                    <TextBlock Text="{x:Bind Name}" FontSize="13" />
                                    <TextBlock
                                        Text="{x:Bind CountText}"
                                        FontSize="13"
                                        Foreground="{ThemeResource AppTextTertiaryBrush}" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
