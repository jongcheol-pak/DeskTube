<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DeskTube.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrls="using:DeskTube.Controls"
    xmlns:local="using:DeskTube.Views"
    xmlns:vm="using:DeskTube.ViewModels">
    <!-- 시안 홈: 로그인 영역(우상단) + 제목/부제 → URL 입력+재생(카드 안 재생 중 pill) → 모니터 카드 → (하단) 빠른 재생.
         시안이 overflow:auto + 빠른 재생 하단 정렬(margin-top:auto)이라 ScrollViewer 안 Grid의
         MinHeight를 뷰포트에 맞춰(코드비하인드) 둘 다 재현한다. -->
    <!-- 가로 축소 시 요소 겹침 방지 — 콘텐츠 최소 폭 미만이면 가로 스크롤 (사용자 보고 수정).
         Layout의 Width(콘텐츠 1000 + 페이지 패딩)는 파생값이라 코드비하인드에서 토큰으로 계산한다 -->
    <ScrollViewer
        x:Name="Root"
        SizeChanged="OnRootSizeChanged"
        HorizontalScrollMode="Enabled"
        HorizontalScrollBarVisibility="Auto">
        <Grid
            x:Name="Layout"
            Padding="{StaticResource AppPagePadding}"
            RowSpacing="12"
            HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 로그인 영역(위) + 제목/부제(아래) — 세로 배치로 창 축소 시 겹침 원인 제거 (사용자 확정 순서) -->
            <StackPanel Grid.Row="0" Spacing="16" Margin="0,0,0,12">
                <!-- 유튜브 계정 상태 + 로그인/로그아웃 (공용 계정 패널 — 설정 카드와 동일 바인딩, FR-15) -->
                <StackPanel Spacing="6" HorizontalAlignment="Right">
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="14"
                        HorizontalAlignment="Right">
                        <TextBlock
                            Text="{x:Bind ViewModel.Account.AccountStatusText, Mode=OneWay}"
                            Style="{StaticResource BodyTextBlockStyle}"
                            FontSize="13"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource AppTextTertiaryBrush}" />
                        <Button
                            Command="{x:Bind ViewModel.Account.AccountActionCommand}"
                            IsEnabled="{x:Bind ViewModel.Account.AccountActionAvailable, Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <!-- 구글 "G" 로고 — 공용 컨트롤 (설정 로그인 버튼과 공유, 색·path는 컨트롤이 소유) -->
                                <ctrls:GoogleLogoIcon VerticalAlignment="Center" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.Account.AccountButtonText, Mode=OneWay}"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <!-- 프리미엄 안내 (FR-15) — 1줄 고정 (줄바꿈 없음, 사용자 확정) -->
                    <TextBlock
                        x:Uid="HomePremiumHint"
                        FontSize="12"
                        HorizontalAlignment="Right"
                        Foreground="{ThemeResource AppTextTertiaryBrush}" />
                </StackPanel>
                <!-- 제목 + 부제 (시안 30px/14px) -->
                <StackPanel Spacing="8">
                    <TextBlock
                        x:Uid="HomeHeader"
                        FontSize="30"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource AppTextStrongBrush}" />
                    <TextBlock
                        x:Uid="HomeSubtitle"
                        FontSize="14"
                        Foreground="{ThemeResource AppTextSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- URL 입력 카드 (설정 화면과 동일한 카드 형식 — 사용자 확정) -->
            <Border Grid.Row="1" Style="{StaticResource AppCardBorderStyle}" Padding="24,22">
                <StackPanel Spacing="14">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <!-- WinUI TextBox 템플릿은 VerticalContentAlignment를 무시하므로 세로 패딩으로 중앙 정렬 -->
                        <TextBox
                            x:Uid="HomeUrlBox"
                            x:Name="UrlBox"
                            Grid.Column="0"
                            Height="48"
                            Padding="18,13"
                            Background="{ThemeResource AppInputBackgroundBrush}"
                            BorderBrush="{ThemeResource AppInputBorderBrush}"
                            CornerRadius="{StaticResource AppCardCornerRadius}"
                            Text="{x:Bind ViewModel.Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            KeyDown="OnUrlBoxKeyDown" />
                        <Button
                            Grid.Column="1"
                            Height="48"
                            Padding="26,0"
                            Style="{StaticResource AccentButtonStyle}"
                            CornerRadius="{StaticResource AppCardCornerRadius}"
                            Command="{x:Bind ViewModel.PlayCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE768;" FontSize="14" />
                                <TextBlock x:Uid="HomePlayLabel" FontSize="14" FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- 재생 중 pill (시안 — 코럴 dot + 라벨 + 정지 버튼, 재생 중에만) -->
                    <Border
                        Visibility="{x:Bind ViewModel.IsPlaying, Mode=OneWay}"
                        Background="{ThemeResource AppTintBackgroundBrush}"
                        BorderBrush="{ThemeResource AppTintBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource AppPillCornerRadius}"
                        Padding="18,8,8,8"
                        HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8" Fill="{ThemeResource AppAccentBrush}" VerticalAlignment="Center" />
                            <TextBlock
                                Text="{x:Bind ViewModel.PlayingLabel, Mode=OneWay}"
                                FontSize="13"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource AppTintTextBrush}" />
                            <Button
                                Padding="14,5"
                                Background="{ThemeResource AppTintButtonBackgroundBrush}"
                                BorderThickness="0"
                                CornerRadius="{StaticResource AppStopButtonCornerRadius}"
                                Command="{x:Bind ViewModel.StopCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE71A;" FontSize="11" Foreground="{ThemeResource AppTintButtonTextBrush}" />
                                    <TextBlock
                                        x:Uid="HomeStopLabel"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource AppTintButtonTextBrush}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- 재생 모니터 카드 (시안 — 대형 카드, 클릭 토글) -->
            <Border Grid.Row="2" Style="{StaticResource AppCardBorderStyle}" Padding="24,22">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock
                            x:Uid="HomeMonitorsTitle"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource AppTextPrimaryBrush}" />
                        <TextBlock
                            x:Uid="HomeMonitorsHint"
                            FontSize="13"
                            VerticalAlignment="Bottom"
                            Foreground="{ThemeResource AppTextTertiaryBrush}" />
                    </StackPanel>
                    <ctrls:MonitorCardsControl
                        Monitors="{x:Bind ViewModel.MonitorPanel.Monitors}"
                        IsLarge="True"
                        MuteToggleCommand="{x:Bind ViewModel.MonitorPanel.ToggleMuteCommand}" />
                </StackPanel>
            </Border>

            <!-- 빠른 재생 칩 카드 (시안 — 페이지 하단 정렬, 리스트 없으면 섹션 숨김) -->
            <Border
                Grid.Row="4"
                Style="{StaticResource AppCardBorderStyle}"
                Padding="24,22"
                Visibility="{x:Bind ViewModel.HasChips, Mode=OneWay}">
                <StackPanel Spacing="12">
                    <TextBlock
                        x:Uid="HomeQuickPlayTitle"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource AppTextPrimaryBrush}" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.QuickChips}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VariableSizedWrapGrid Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:QuickChip">
                                <Button
                                    Style="{StaticResource AppChipButtonStyle}"
                                    Margin="0,0,12,12"
                                    Click="OnChipClick">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon Glyph="&#xE8FD;" FontSize="13" />
                                        <TextBlock Text="{x:Bind Name}" FontSize="13" />
                                        <!-- 재생 중 표시 (코럴 스피커 — 플레이리스트 목록과 동일, now-playing plan T3) -->
                                        <FontIcon
                                            Glyph="&#xE767;"
                                            FontSize="13"
                                            Foreground="{ThemeResource AppAccentBrush}"
                                            AutomationProperties.Name="{x:Bind local:HomePage.NowPlayingLabel()}"
                                            ToolTipService.ToolTip="{x:Bind local:HomePage.NowPlayingLabel()}"
                                            Visibility="{x:Bind IsNowPlaying, Mode=OneWay}" />
                                        <TextBlock
                                            Text="{x:Bind CountText}"
                                            FontSize="13"
                                            Foreground="{ThemeResource AppTextTertiaryBrush}" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
