<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DeskTube.Controls.MonitorCardsControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DeskTube.Controls"
    xmlns:vm="using:DeskTube.ViewModels">
    <!-- 모니터 카드 패널 (plan T4, 시안) — 홈 대형(300×188)·설정 소형(200×125) 두 변형.
         변형별 수치가 달라 템플릿 2벌로 명시한다 (파라미터 간접화보다 추적 쉬움 — 규칙 5-1). -->
    <UserControl.Resources>
        <DataTemplate x:Key="LargeCardTemplate" x:DataType="vm:MonitorChoice">
            <StackPanel Spacing="10" Margin="0,0,28,12">
                <Button
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    CornerRadius="{StaticResource AppMonitorCardCornerRadius}"
                    Click="OnCardClick"
                    PointerEntered="OnCardPointerEntered"
                    PointerExited="OnCardPointerExited"
                    AutomationProperties.Name="{x:Bind DisplayName}">
                    <Grid
                        Width="300"
                        Height="188"
                        CornerRadius="{StaticResource AppMonitorCardCornerRadius}"
                        BorderThickness="2"
                        BorderBrush="{x:Bind local:MonitorCardsControl.CardBorder(IsSelected), Mode=OneWay}"
                        Background="{x:Bind local:MonitorCardsControl.CardBackground(IsSelected), Mode=OneWay}">
                        <TextBlock
                            Text="{x:Bind Number}"
                            FontSize="36"
                            FontWeight="ExtraLight"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{x:Bind local:MonitorCardsControl.NumberBrush(IsSelected), Mode=OneWay}" />
                        <Border
                            Visibility="{x:Bind local:MonitorCardsControl.BadgeVisibility(ShowAudioBadge), Mode=OneWay}"
                            Background="{ThemeResource AppAccentBrush}"
                            CornerRadius="{StaticResource AppBadgeCornerRadius}"
                            Padding="9,3"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,10,10,0">
                            <TextBlock
                                x:Uid="MonitorAudioBadge"
                                FontSize="11"
                                FontWeight="Bold"
                                Foreground="{ThemeResource AppTextStrongBrush}" />
                        </Border>
                        <TextBlock
                            Text="{x:Bind ResolutionLabel}"
                            FontSize="12"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Margin="12,0,0,10"
                            Foreground="{x:Bind local:MonitorCardsControl.SubBrush(IsSelected), Mode=OneWay}" />
                    </Grid>
                </Button>
                <!-- 모니터 받침 (시안 70×5) -->
                <Border
                    Width="70"
                    Height="5"
                    CornerRadius="{StaticResource AppMonitorStandCornerRadius}"
                    Background="{ThemeResource AppMonitorStandBrush}"
                    HorizontalAlignment="Center" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="CompactCardTemplate" x:DataType="vm:MonitorChoice">
            <StackPanel Spacing="7" Margin="0,0,20,10">
                <Button
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    CornerRadius="{StaticResource AppCardCornerRadius}"
                    Click="OnCardClick"
                    PointerEntered="OnCardPointerEntered"
                    PointerExited="OnCardPointerExited"
                    AutomationProperties.Name="{x:Bind DisplayName}">
                    <Grid
                        Width="200"
                        Height="125"
                        CornerRadius="{StaticResource AppCardCornerRadius}"
                        BorderThickness="2"
                        BorderBrush="{x:Bind local:MonitorCardsControl.CardBorder(IsSelected), Mode=OneWay}"
                        Background="{x:Bind local:MonitorCardsControl.CardBackground(IsSelected), Mode=OneWay}">
                        <TextBlock
                            Text="{x:Bind Number}"
                            FontSize="26"
                            FontWeight="ExtraLight"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{x:Bind local:MonitorCardsControl.NumberBrush(IsSelected), Mode=OneWay}" />
                        <Border
                            Visibility="{x:Bind local:MonitorCardsControl.BadgeVisibility(ShowAudioBadge), Mode=OneWay}"
                            Background="{ThemeResource AppAccentBrush}"
                            CornerRadius="{StaticResource AppBadgeCornerRadius}"
                            Padding="8,2"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,7,7,0">
                            <TextBlock
                                x:Uid="MonitorAudioBadge"
                                FontSize="10"
                                FontWeight="Bold"
                                Foreground="{ThemeResource AppTextStrongBrush}" />
                        </Border>
                        <TextBlock
                            Text="{x:Bind ResolutionLabel}"
                            FontSize="11"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Margin="9,0,0,7"
                            Foreground="{x:Bind local:MonitorCardsControl.SubBrush(IsSelected), Mode=OneWay}" />
                    </Grid>
                </Button>
                <Border
                    Width="48"
                    Height="4"
                    CornerRadius="{StaticResource AppMonitorStandCornerRadius}"
                    Background="{ThemeResource AppMonitorStandBrush}"
                    HorizontalAlignment="Center" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <!-- wrap 배치 (시안 flex-wrap) — 셀 크기는 첫 항목 크기를 따른다 -->
    <ItemsControl x:Name="Cards" ItemsSource="{x:Bind Monitors, Mode=OneWay}">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <VariableSizedWrapGrid Orientation="Horizontal" />
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
    </ItemsControl>
</UserControl>
