<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DeskTube.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 시안 셸: 창 배경 = 루트 토큰, 사이드바 220px, 콘텐츠는 좌상단만 둥근 카드 (plan T3·D13) -->
    <Grid Background="{ThemeResource AppRootBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 커스텀 타이틀바 (시안 44px — 앱 아이콘 18×18 r5 + 앱명 13px. 캡션 버튼은 시스템, Q3) -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="{StaticResource AppTitleBarHeight}">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="16,0,0,0">
                <!-- Border+ImageBrush — Image는 CornerRadius 클리핑이 안 돼 배경 브러시로 라운드 처리 -->
                <Border Width="18" Height="18" CornerRadius="{StaticResource AppIconCornerRadius}">
                    <Border.Background>
                        <ImageBrush ImageSource="ms-appx:///Assets/Square44x44Logo.png" Stretch="UniformToFill" />
                    </Border.Background>
                </Border>
                <!-- 앱명(브랜드명)은 번역 대상이 아니라 직접 표기 -->
                <TextBlock
                    Text="DeskTube"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource AppTextPrimaryBrush}"
                    VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- 설정 셸 — 시안 구조: 상단 홈/플레이리스트/설정, 하단(footer) 정보 (plan T3) -->
        <NavigationView
            x:Name="Nav"
            Grid.Row="1"
            PaneDisplayMode="Left"
            OpenPaneLength="{StaticResource AppSidebarWidth}"
            IsPaneToggleButtonVisible="False"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            SelectionChanged="OnNavSelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Uid="NavHome" x:Name="NavHomeItem" Tag="home" Icon="Home" />
                <NavigationViewItem x:Uid="NavPlaylists" x:Name="NavPlaylistsItem" Tag="playlists" Icon="List" />
                <NavigationViewItem x:Uid="NavSettings" Tag="settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <NavigationViewItem x:Uid="NavAbout" Tag="about">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE946;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>
            <!-- 콘텐츠 카드 — 좌상단만 라운드, 우·하 테두리 없음 (시안 #202023/#2C2C30) -->
            <Border
                Background="{ThemeResource AppContentBackgroundBrush}"
                BorderBrush="{ThemeResource AppContentBorderBrush}"
                BorderThickness="1,1,0,0"
                CornerRadius="{StaticResource AppContentCornerRadius}">
                <Frame x:Name="ContentFrame" />
            </Border>
        </NavigationView>
        <!-- 트레이 진입 안내 (재생할 리스트 없음 등 — plan T1 Edge). 셸 위 오버레이 -->
        <InfoBar
            x:Name="NoticeBar"
            Grid.Row="1"
            IsOpen="False"
            Severity="Informational"
            VerticalAlignment="Top"
            HorizontalAlignment="Center"
            MaxWidth="600"
            Margin="16,48,16,0" />
    </Grid>
</Window>
