<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DeskTube.Views.PlaylistsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:DeskTube.ViewModels"
    xmlns:local="using:DeskTube.Views">
    <!-- 시안 플레이리스트: 좌 300px 패널(제목·새 리스트·목록) / 우(추가 입력·리스트명+곡수+듣기 버튼·트랙 행).
         컬럼 헤더 행은 시안에 없어 제거 (plan D6).
         최소 폭 900 — 좁은 창은 가로 스크롤(세로는 내부 ListView가 처리 — 가로 전용 래퍼, 사용자 확정).
         가로 래퍼는 콘텐츠를 무한 폭으로 측정하므로 MaxWidth를 뷰포트에 맞춰(코드비하인드) 긴 제목이
         페이지 폭을 키우지 않고 말줄임되게 한다 -->
    <ScrollViewer
        x:Name="Root"
        SizeChanged="OnRootSizeChanged"
        HorizontalScrollMode="Enabled"
        HorizontalScrollBarVisibility="Auto"
        VerticalScrollMode="Disabled"
        VerticalScrollBarVisibility="Disabled">
    <Grid x:Name="Layout" MinWidth="{StaticResource AppPageContentWidth}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 좌측: 리스트 목록 (생성·이름변경·삭제 — 이름변경/삭제는 우클릭 메뉴 유지) -->
        <Border
            Grid.Row="1"
            Grid.Column="0"
            BorderBrush="{ThemeResource AppDividerBrush}"
            BorderThickness="0,0,1,0"
            Padding="18,32,18,18">
            <Grid RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock
                    x:Uid="PlaylistsHeader"
                    Grid.Row="0"
                    Margin="8,0"
                    FontSize="22"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource AppTextStrongBrush}" />
                <!-- 새 플레이리스트 (시안 점선 — XAML 점선 미지원이라 전용 테두리 색으로 근사, hover 코럴) -->
                <Button
                    Grid.Row="1"
                    Style="{StaticResource AppDashedButtonStyle}"
                    Click="OnNewPlaylistClick"
                    PointerEntered="OnDashedButtonPointerEntered"
                    PointerExited="OnDashedButtonPointerExited"
                    IsEnabled="{x:Bind ViewModel.IsReady, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE710;" FontSize="12" />
                        <TextBlock x:Uid="NewPlaylistLabel" FontSize="13" />
                    </StackPanel>
                </Button>
                <ListView
                    x:Name="PlaylistListView"
                    Grid.Row="2"
                    ItemsSource="{x:Bind ViewModel.Playlists}"
                    SelectedItem="{x:Bind ViewModel.SelectedPlaylist, Mode=TwoWay}"
                    SelectionMode="Single">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <!-- 좌우 패딩 0 — 활성 인디케이터를 항목 왼쪽 끝(left:0)에 붙이기 위함 (시안).
                                 텍스트 들여쓰기 14는 템플릿(바 3 + 마진 11)이 담당 -->
                            <Setter Property="Padding" Value="0,12" />
                            <Setter Property="CornerRadius" Value="{StaticResource AppCardCornerRadius}" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:PlaylistEntry">
                            <Grid>
                                <Grid.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem x:Uid="RenameMenuItem" Click="OnRenameClick" />
                                        <MenuFlyoutItem x:Uid="DeleteMenuItem" Click="OnDeleteClick" />
                                    </MenuFlyout>
                                </Grid.ContextFlyout>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <!-- 활성 인디케이터 (시안 — 좌측 3px 코럴, 상하 12 인셋은 컨테이너 패딩이 담당) -->
                                <Rectangle
                                    Grid.Column="0"
                                    Width="3"
                                    RadiusX="2"
                                    RadiusY="2"
                                    Fill="{ThemeResource AppAccentBrush}"
                                    VerticalAlignment="Stretch"
                                    Visibility="{x:Bind IsActive, Mode=OneWay}" />
                                <TextBlock
                                    Grid.Column="1"
                                    Margin="11,0,8,0"
                                    Text="{x:Bind Name, Mode=OneWay}"
                                    FontSize="13"
                                    FontWeight="{x:Bind local:PlaylistsPage.ActiveWeight(IsActive), Mode=OneWay}"
                                    Foreground="{x:Bind local:PlaylistsPage.ActiveNameBrush(IsActive), Mode=OneWay}"
                                    VerticalAlignment="Center"
                                    TextTrimming="CharacterEllipsis" />
                                <!-- 재생 중 표시 (코럴 스피커 — 소리 배지와 동일 글리프, now-playing plan T2) -->
                                <FontIcon
                                    Grid.Column="2"
                                    Margin="0,0,10,0"
                                    Glyph="&#xE767;"
                                    FontSize="13"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource AppAccentBrush}"
                                    AutomationProperties.Name="{x:Bind local:PlaylistsPage.NowPlayingLabel()}"
                                    ToolTipService.ToolTip="{x:Bind local:PlaylistsPage.NowPlayingLabel()}"
                                    Visibility="{x:Bind IsNowPlaying, Mode=OneWay}" />
                                <TextBlock
                                    Grid.Column="3"
                                    Margin="0,0,14,0"
                                    Text="{x:Bind ItemCount, Mode=OneWay}"
                                    FontSize="13"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource AppTextTertiaryBrush}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- 우측: 선택 리스트의 항목 — 차트형 행 (FR-18 유지, 시안 재스타일) -->
        <Grid Grid.Row="1" Grid.Column="1" Padding="36,32" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 추가 입력 (시안 h42, 최상단) -->
            <Grid Grid.Row="0" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!-- WinUI TextBox 템플릿은 VerticalContentAlignment를 무시하므로 세로 패딩으로 중앙 정렬 -->
                <TextBox
                    x:Uid="ItemUrlBox"
                    Grid.Column="0"
                    Height="42"
                    Padding="16,10"
                    Background="{ThemeResource AppInputBackgroundBrush}"
                    BorderBrush="{ThemeResource AppInputBorderBrush}"
                    CornerRadius="{StaticResource AppCardCornerRadius}"
                    Text="{x:Bind ViewModel.NewUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    IsEnabled="{x:Bind ViewModel.CanAddItem, Mode=OneWay}"
                    KeyDown="OnUrlBoxKeyDown" />
                <Button
                    x:Uid="AddItemButton"
                    Grid.Column="1"
                    Height="42"
                    Padding="20,0"
                    Style="{StaticResource AppPillButtonStyle}"
                    PointerEntered="OnOutlineButtonPointerEntered"
                    PointerExited="OnOutlineButtonPointerExited"
                    Command="{x:Bind ViewModel.AddItemCommand}"
                    IsEnabled="{x:Bind ViewModel.CanAddItem, Mode=OneWay}" />
            </Grid>

            <!-- 리스트명 + 곡수 + 셔플듣기/전체듣기 (시안 헤더 행) -->
            <Grid Grid.Row="1" ColumnSpacing="14" Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                    <TextBlock
                        Text="{x:Bind ViewModel.SelectedPlaylist.Name, Mode=OneWay}"
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="{ThemeResource AppTextStrongBrush}"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock
                        Text="{x:Bind FormatCount(ViewModel.SelectedPlaylist.ItemCount), Mode=OneWay}"
                        FontSize="13"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,3"
                        Foreground="{ThemeResource AppTextTertiaryBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <!-- 셔플듣기/전체듣기 — 재생을 시작한 모드의 버튼에만 문구 뒤 정지 아이콘을 표시하고
                         그 버튼 클릭 시 정지한다 (문구는 유지 — mode-indicator plan D1·D4) -->
                    <Button
                        Style="{StaticResource AppPillButtonStyle}"
                        PointerEntered="OnOutlineButtonPointerEntered"
                        PointerExited="OnOutlineButtonPointerExited"
                        Command="{x:Bind ViewModel.ShuffleAllCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8B1;" FontSize="13" />
                            <TextBlock x:Uid="ShuffleAllLabel" FontSize="13" />
                            <FontIcon
                                Glyph="&#xE71A;"
                                FontSize="12"
                                AutomationProperties.Name="{x:Bind local:PlaylistsPage.StopLabel()}"
                                ToolTipService.ToolTip="{x:Bind local:PlaylistsPage.StopLabel()}"
                                Visibility="{x:Bind ViewModel.IsShufflePlaying, Mode=OneWay}" />
                        </StackPanel>
                    </Button>
                    <Button
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="18,9"
                        CornerRadius="{StaticResource AppCardCornerRadius}"
                        Command="{x:Bind ViewModel.PlayCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE768;" FontSize="13" />
                            <TextBlock x:Uid="PlayAllLabel" FontSize="13" FontWeight="SemiBold" />
                            <FontIcon
                                Glyph="&#xE71A;"
                                FontSize="12"
                                AutomationProperties.Name="{x:Bind local:PlaylistsPage.StopLabel()}"
                                ToolTipService.ToolTip="{x:Bind local:PlaylistsPage.StopLabel()}"
                                Visibility="{x:Bind ViewModel.IsSequentialPlaying, Mode=OneWay}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <TextBlock
                x:Uid="NoSelectionText"
                Grid.Row="2"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Style="{StaticResource BodyTextBlockStyle}"
                Visibility="{x:Bind InvertVisibility(ViewModel.HasSelection), Mode=OneWay}" />

            <!-- ListView 기본 가상화 유지 (1000개 대비), 드래그 정렬 지원.
                 행 조작(위/아래/삭제)은 우클릭 메뉴, 행에는 재생 버튼만. 컬럼 헤더 행 없음 (시안·D6). -->
            <ListView
                x:Name="ItemListView"
                Grid.Row="2"
                ItemsSource="{x:Bind ViewModel.Items}"
                SelectionMode="None"
                CanDragItems="True"
                CanReorderItems="True"
                AllowDrop="True"
                Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay}">
                <!-- 공유 팝업 (share plan T1·D1) — 우클릭한 행을 앵커로 ShowAt하는 페이지 단일 Flyout.
                     어두운 라운드 바(URL 읽기 전용 + 복사) — 첨부 시안 스타일 참고, 값은 토큰만 사용. -->
                <FlyoutBase.AttachedFlyout>
                    <Flyout x:Name="ShareFlyout" Placement="Bottom">
                        <Flyout.FlyoutPresenterStyle>
                            <Style TargetType="FlyoutPresenter">
                                <Setter Property="Background" Value="{ThemeResource AppInputBackgroundBrush}" />
                                <Setter Property="BorderBrush" Value="{ThemeResource AppInputBorderBrush}" />
                                <Setter Property="CornerRadius" Value="{StaticResource AppPillCornerRadius}" />
                                <Setter Property="Padding" Value="14,8" />
                            </Style>
                        </Flyout.FlyoutPresenterStyle>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBox
                                x:Name="ShareUrlBox"
                                IsReadOnly="True"
                                BorderThickness="0"
                                Background="Transparent"
                                Width="340"
                                VerticalAlignment="Center" />
                            <Button
                                x:Uid="Playlists_ShareCopy"
                                Click="OnShareCopyClick"
                                CornerRadius="{StaticResource AppCardCornerRadius}"
                                VerticalAlignment="Center" />
                        </StackPanel>
                    </Flyout>
                </FlyoutBase.AttachedFlyout>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="14,12" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Setter Property="BorderBrush" Value="{ThemeResource AppDividerBrush}" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:PlaylistItemEntry">
                        <Grid ColumnSpacing="16">
                            <Grid.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem x:Uid="ItemUpMenuItem" Click="OnMoveUpClick">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE74A;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem x:Uid="ItemDownMenuItem" Click="OnMoveDownClick">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE74B;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem x:Uid="ItemShareMenuItem" Click="OnShareClick">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE72D;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem x:Uid="ItemDeleteMenuItem" Click="OnRemoveItemClick">
                                        <MenuFlyoutItem.Icon>
                                            <SymbolIcon Symbol="Delete" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Grid.ContextFlyout>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22" />
                                <ColumnDefinition Width="64" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <!-- 순위 번호 / 재생 중 스피커 글리프 겹침 (col0) — 재생 중인 곡은 번호 대신 코럴 스피커
                                 (좌측 리스트·홈 칩과 동일 E767, now-playing item plan D3) -->
                            <TextBlock
                                Grid.Column="0"
                                Text="{x:Bind Rank, Mode=OneWay}"
                                FontSize="14"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource AppTextTertiaryBrush}"
                                Visibility="{x:Bind local:PlaylistsPage.RankVisibility(IsNowPlaying), Mode=OneWay}" />
                            <FontIcon
                                Grid.Column="0"
                                Glyph="&#xE767;"
                                FontSize="14"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource AppAccentBrush}"
                                AutomationProperties.Name="{x:Bind local:PlaylistsPage.NowPlayingLabel()}"
                                ToolTipService.ToolTip="{x:Bind local:PlaylistsPage.NowPlayingLabel()}"
                                Visibility="{x:Bind IsNowPlaying, Mode=OneWay}" />
                            <!-- 썸네일 64×40 (시안 16:9 — 유튜브 원본 비율 그대로) -->
                            <Border
                                Grid.Column="1"
                                Width="64"
                                Height="40"
                                CornerRadius="{StaticResource AppControlCornerRadius}"
                                Background="{ThemeResource AppThumbPlaceholderBackgroundBrush}"
                                VerticalAlignment="Center">
                                <Image Stretch="UniformToFill">
                                    <Image.Source>
                                        <BitmapImage UriSource="{x:Bind ThumbnailUri}" DecodePixelWidth="128" />
                                    </Image.Source>
                                </Image>
                            </Border>
                            <StackPanel
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Spacing="2">
                                <TextBlock
                                    Text="{x:Bind DisplayTitle, Mode=OneWay}"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource AppTextPrimaryBrush}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Text="{x:Bind ChannelName, Mode=OneWay}"
                                    FontSize="12"
                                    Foreground="{ThemeResource AppTextTertiaryBrush}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <!-- 행 재생/정지 토글 — 재생 중인 곡의 행만 정지 표시, 접근성 이름도 상태 반영 (stop-toggle plan D2) -->
                            <Button
                                Grid.Column="3"
                                Width="34"
                                Height="34"
                                Padding="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                CornerRadius="{StaticResource AppCircleButtonCornerRadius}"
                                Background="Transparent"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource AppInputBorderBrush}"
                                AutomationProperties.Name="{x:Bind local:PlaylistsPage.RowPlayName(IsNowPlaying), Mode=OneWay}"
                                PointerEntered="OnRowPlayPointerEntered"
                                PointerExited="OnRowPlayPointerExited"
                                Click="OnPlayItemClick">
                                <FontIcon
                                    Glyph="{x:Bind local:PlaylistsPage.RowPlayGlyph(IsNowPlaying), Mode=OneWay}"
                                    FontSize="12"
                                    Foreground="{ThemeResource AppChipTextBrush}" />
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
    </ScrollViewer>
</Page>
