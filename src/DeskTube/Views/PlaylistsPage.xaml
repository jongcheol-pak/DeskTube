<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DeskTube.Views.PlaylistsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:DeskTube.ViewModels"
    xmlns:models="using:DeskTube.Models">
    <Grid Padding="36,24,40,24" ColumnSpacing="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" MinWidth="220" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <TextBlock
            x:Uid="PlaylistsHeader"
            Grid.Row="0"
            Grid.ColumnSpan="2"
            Style="{StaticResource TitleTextBlockStyle}" />

        <InfoBar
            Grid.Row="1"
            Grid.ColumnSpan="2"
            IsOpen="{x:Bind ViewModel.IsNoticeOpen, Mode=TwoWay}"
            Message="{x:Bind ViewModel.NoticeMessage, Mode=OneWay}"
            Severity="{x:Bind ViewModel.NoticeSeverity, Mode=OneWay}" />

        <!-- 좌측: 리스트 목록 (생성·이름변경·삭제 — 이름변경/삭제는 우클릭 메뉴) -->
        <Grid Grid.Row="2" Grid.Column="0" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Button
                x:Uid="NewPlaylistButton"
                Grid.Row="0"
                HorizontalAlignment="Stretch"
                Click="OnNewPlaylistClick"
                IsEnabled="{x:Bind ViewModel.IsReady, Mode=OneWay}" />
            <ListView
                x:Name="PlaylistListView"
                Grid.Row="1"
                ItemsSource="{x:Bind ViewModel.Playlists}"
                SelectedItem="{x:Bind ViewModel.SelectedPlaylist, Mode=TwoWay}"
                SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:PlaylistEntry">
                        <Grid ColumnSpacing="8">
                            <Grid.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem x:Uid="RenameMenuItem" Click="OnRenameClick" />
                                    <MenuFlyoutItem x:Uid="DeleteMenuItem" Click="OnDeleteClick" />
                                </MenuFlyout>
                            </Grid.ContextFlyout>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                Text="{x:Bind Name, Mode=OneWay}"
                                VerticalAlignment="Center"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                Grid.Column="1"
                                Text="{x:Bind ItemCount, Mode=OneWay}"
                                VerticalAlignment="Center"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- 우측: 선택 리스트의 항목 -->
        <Grid Grid.Row="2" Grid.Column="1" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox
                    x:Uid="ItemUrlBox"
                    Grid.Column="0"
                    Text="{x:Bind ViewModel.NewUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    IsEnabled="{x:Bind ViewModel.CanAddItem, Mode=OneWay}"
                    KeyDown="OnUrlBoxKeyDown" />
                <Button
                    x:Uid="AddItemButton"
                    Grid.Column="1"
                    Command="{x:Bind ViewModel.AddItemCommand}"
                    IsEnabled="{x:Bind ViewModel.CanAddItem, Mode=OneWay}" />
                <Button
                    x:Uid="PlaylistsPlayButton"
                    Grid.Column="2"
                    Style="{StaticResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.PlayCommand}"
                    IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}" />
            </Grid>

            <TextBlock
                x:Uid="NoSelectionText"
                Grid.Row="1"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Style="{StaticResource BodyTextBlockStyle}"
                Visibility="{x:Bind InvertVisibility(ViewModel.HasSelection), Mode=OneWay}" />

            <!-- ListView 기본 가상화 유지 (1000개 대비 — plan T3 Edge), 드래그 정렬 지원 -->
            <ListView
                x:Name="ItemListView"
                Grid.Row="1"
                ItemsSource="{x:Bind ViewModel.Items}"
                SelectionMode="None"
                CanDragItems="True"
                CanReorderItems="True"
                AllowDrop="True"
                Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:PlaylistItem">
                        <Grid ColumnSpacing="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                Text="{x:Bind Url}"
                                VerticalAlignment="Center"
                                TextTrimming="CharacterEllipsis" />
                            <Button x:Uid="ItemUpButton" Grid.Column="1" Click="OnMoveUpClick">
                                <FontIcon Glyph="&#xE74A;" />
                            </Button>
                            <Button x:Uid="ItemDownButton" Grid.Column="2" Click="OnMoveDownClick">
                                <FontIcon Glyph="&#xE74B;" />
                            </Button>
                            <Button x:Uid="ItemDeleteButton" Grid.Column="3" Click="OnRemoveItemClick">
                                <SymbolIcon Symbol="Delete" />
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>
