<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DeskTube.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:DeskTube.ViewModels">
    <!-- 시안 정보: 앱 카드(아이콘 52 + 이름 + 버전·개발자 한 줄) → 개인정보 카드 → 라이선스 카드형 expander -->
    <ScrollViewer Padding="{StaticResource AppPagePadding}">
        <StackPanel MaxWidth="{StaticResource AppSettingsCardMaxWidth}" Spacing="10" HorizontalAlignment="Left">
            <TextBlock
                x:Uid="AboutHeader"
                Style="{StaticResource TitleTextBlockStyle}"
                FontSize="30"
                FontWeight="SemiBold"
                Foreground="{ThemeResource AppTextStrongBrush}"
                Margin="0,0,0,14" />

            <!-- 앱 정보 카드 (FR-11 — 시안: 아이콘 52 r12 + 이름 17 w700 + "버전 x · 개발자" 12.5) -->
            <Border Style="{StaticResource AppCardBorderStyle}" Padding="24,22">
                <StackPanel Orientation="Horizontal" Spacing="18">
                    <Border Width="52" Height="52" CornerRadius="{StaticResource AppLargeIconCornerRadius}" VerticalAlignment="Center">
                        <Border.Background>
                            <ImageBrush ImageSource="ms-appx:///Assets/Square44x44Logo.png" Stretch="UniformToFill" />
                        </Border.Background>
                    </Border>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <!-- 앱명(브랜드명)은 번역 대상이 아니라 직접 표기 -->
                        <TextBlock
                            Text="DeskTube"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            FontSize="17"
                            FontWeight="Bold"
                            Foreground="{ThemeResource AppTextStrongBrush}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            FontSize="12.5"
                            Foreground="{ThemeResource AppTextTertiaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 개인정보 처리방침 카드 (NFR-6) -->
            <Border Style="{StaticResource AppCardBorderStyle}" Padding="24,20">
                <StackPanel Spacing="10">
                    <TextBlock
                        x:Uid="PrivacyTitle"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        FontSize="14"
                        Foreground="{ThemeResource AppTextPrimaryBrush}" />
                    <TextBlock
                        x:Uid="PrivacySummary"
                        Style="{StaticResource BodyTextBlockStyle}"
                        FontSize="12.5"
                        LineHeight="21"
                        Foreground="{ThemeResource AppTextSecondaryBrush}"
                        TextWrapping="Wrap" />
                    <TextBlock
                        x:Uid="PrivacyDocNote"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        FontSize="12"
                        Foreground="{ThemeResource AppTextTertiaryBrush}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- 오픈소스 라이선스 (FR-12 — 시안: 카드형 expander 목록) -->
            <TextBlock
                x:Uid="LicensesTitle"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                FontSize="15"
                Foreground="{ThemeResource AppTextPrimaryBrush}"
                Margin="0,10,0,0" />
            <ItemsControl ItemsSource="{x:Bind ViewModel.Licenses}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:LicenseEntry">
                        <!-- 접힘 기본 — 긴 전문은 펼칠 때만 렌더 (기존 동작 유지) -->
                        <Expander
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Margin="0,0,0,8"
                            Background="{ThemeResource AppCardBackgroundBrush}"
                            BorderBrush="{ThemeResource AppCardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource AppCardCornerRadius}">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock
                                        Text="{x:Bind Id}"
                                        Style="{StaticResource BodyStrongTextBlockStyle}"
                                        FontSize="13.5"
                                        VerticalAlignment="Center" />
                                    <TextBlock
                                        Text="{x:Bind License}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        FontSize="12"
                                        Foreground="{ThemeResource AppTextTertiaryBrush}"
                                        VerticalAlignment="Center" />
                                </StackPanel>
                            </Expander.Header>
                            <TextBlock
                                Text="{x:Bind FullText}"
                                Style="{StaticResource BodyTextBlockStyle}"
                                FontSize="12"
                                LineHeight="20"
                                Foreground="{ThemeResource AppTextTertiaryBrush}"
                                TextWrapping="Wrap"
                                IsTextSelectionEnabled="True" />
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
