<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DeskTube.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:vm="using:DeskTube.ViewModels">
    <!-- 시안 정보: 앱 카드(아이콘 52 + 이름 + 버전·개발자 한 줄) → 개인정보 카드 → 라이선스 카드형 expander -->
    <!-- 콘텐츠 고정 1000 가운데 정렬 — 좁은 창은 가로 스크롤 (사용자 확정) -->
    <ScrollViewer
        Padding="{StaticResource AppPagePadding}"
        HorizontalScrollMode="Enabled"
        HorizontalScrollBarVisibility="Auto">
        <StackPanel Width="{StaticResource AppPageContentWidth}" Spacing="10" HorizontalAlignment="Center">
            <TextBlock
                x:Uid="AboutHeader"
                Style="{StaticResource TitleTextBlockStyle}"
                FontSize="30"
                FontWeight="SemiBold"
                Foreground="{ThemeResource AppTextStrongBrush}"
                Margin="0,0,0,14" />

            <!-- 앱 정보 카드 (FR-11 — 시안: 아이콘 52 r12 + 이름 17 w700 + "버전 x · 개발자" 12.5) -->
            <Border Style="{StaticResource AppCardBorderStyle}" Padding="24,22">
                <StackPanel Orientation="Horizontal" Spacing="18">
                    <Border Width="52" Height="52" CornerRadius="{StaticResource AppLargeIconCornerRadius}" VerticalAlignment="Center">
                        <Border.Background>
                            <ImageBrush ImageSource="ms-appx:///Assets/Square44x44Logo.png" Stretch="UniformToFill" />
                        </Border.Background>
                    </Border>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <!-- 앱명은 언어별 표기(ko 데스크튜브 — appname plan T4) — 생성자에서 AppDisplayName 리소스로 배정 -->
                        <TextBlock
                            x:Name="AppNameText"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            FontSize="17"
                            FontWeight="Bold"
                            Foreground="{ThemeResource AppTextStrongBrush}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            FontSize="12.5"
                            Foreground="{ThemeResource AppTextTertiaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 개인정보 처리방침 카드 (NFR-6) -->
            <Border Style="{StaticResource AppCardBorderStyle}" Padding="24,20">
                <StackPanel Spacing="10">
                    <TextBlock
                        x:Uid="PrivacyTitle"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        FontSize="14"
                        Foreground="{ThemeResource AppTextPrimaryBrush}" />
                    <TextBlock
                        x:Uid="PrivacySummary"
                        Style="{StaticResource BodyTextBlockStyle}"
                        FontSize="12.5"
                        LineHeight="21"
                        Foreground="{ThemeResource AppTextSecondaryBrush}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- 오픈소스 라이선스 (FR-12 — 클릭 시 공식 사이트 이동, 전문은 패키지 동봉만) -->
            <TextBlock
                x:Uid="LicensesTitle"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                FontSize="15"
                Foreground="{ThemeResource AppTextPrimaryBrush}"
                Margin="0,10,0,0" />
            <ItemsControl ItemsSource="{x:Bind ViewModel.Licenses}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:LicenseEntry">
                        <controls:SettingsCard
                            Margin="0,0,0,8"
                            Header="{x:Bind Id}"
                            Description="{x:Bind License}"
                            IsClickEnabled="True"
                            Click="OnLicenseCardClick">
                            <controls:SettingsCard.ActionIcon>
                                <FontIcon Glyph="&#xE8A7;" FontSize="14" />
                            </controls:SettingsCard.ActionIcon>
                        </controls:SettingsCard>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
