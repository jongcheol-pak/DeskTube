<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DeskTube.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:ctrls="using:DeskTube.Controls">
    <!-- 시안 설정: 그룹 헤더(화면/소리/일반) + 카드 순서 재배열. 테마 카드 없음(다크 고정), 재생 순서 카드 없음(2026-07-17 제거) -->
    <!-- 콘텐츠 고정 1000 가운데 정렬 — 좁은 창은 가로 스크롤 (사용자 확정) -->
    <ScrollViewer
        Padding="{StaticResource AppPagePadding}"
        HorizontalScrollMode="Enabled"
        HorizontalScrollBarVisibility="Auto">
        <StackPanel Width="{StaticResource AppPageContentWidth}" Spacing="10" HorizontalAlignment="Center">
            <TextBlock
                x:Uid="SettingsHeader"
                Style="{StaticResource TitleTextBlockStyle}"
                FontSize="30"
                FontWeight="SemiBold"
                Foreground="{ThemeResource AppTextStrongBrush}"
                Margin="0,0,0,14" />

            <!-- StackPanel엔 IsEnabled가 없어 Control 래퍼로 일괄 비활성 (서비스 준비 전) -->
            <ContentControl
                IsEnabled="{x:Bind ViewModel.IsReady, Mode=OneWay}"
                IsTabStop="False"
                HorizontalContentAlignment="Stretch">
            <StackPanel Spacing="10">
                <!-- ═ 화면 ═ -->
                <TextBlock x:Uid="SettingsGroupDisplay" Style="{StaticResource AppGroupHeaderTextStyle}" Margin="4,4,4,2" />

                <!-- 재생 모니터 — 시각 카드 클릭 토글, 최소 1개 강제 (T4 공용 컨트롤) -->
                <Border Style="{StaticResource AppCardBorderStyle}" Padding="24,20">
                    <StackPanel Spacing="18">
                        <StackPanel Spacing="3">
                            <TextBlock
                                x:Uid="MonitorsCardTitle"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource AppTextPrimaryBrush}" />
                            <TextBlock
                                x:Uid="MonitorsCardDescription"
                                FontSize="12.5"
                                Foreground="{ThemeResource AppTextTertiaryBrush}" />
                        </StackPanel>
                        <ctrls:MonitorCardsControl Monitors="{x:Bind ViewModel.MonitorPanel.Monitors}" IsLarge="False" />
                    </StackPanel>
                </Border>

                <!-- 동영상 크기 모드 (FR-16 — 채움/맞춤/늘리기) -->
                <controls:SettingsCard x:Uid="FitModeCard">
                    <ComboBox
                        MinWidth="150"
                        ItemsSource="{x:Bind ViewModel.FitModeOptions}"
                        SelectedIndex="{x:Bind ViewModel.FitModeIndex, Mode=TwoWay}" />
                </controls:SettingsCard>

                <!-- 화질 스케일 + 유튜브 자동 결정 안내 (시안 코럴 틴트 배너) -->
                <controls:SettingsCard x:Uid="QualityCard">
                    <ComboBox
                        MinWidth="150"
                        ItemsSource="{x:Bind ViewModel.QualityOptions}"
                        SelectedIndex="{x:Bind ViewModel.QualityIndex, Mode=TwoWay}" />
                </controls:SettingsCard>
                <InfoBar
                    x:Uid="QualityNote"
                    IsOpen="True"
                    IsClosable="False"
                    Severity="Informational"
                    Background="{ThemeResource AppTintBackgroundBrush}"
                    BorderBrush="{ThemeResource AppTintBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource AppCardCornerRadius}"
                    Foreground="{ThemeResource AppTintBodyBrush}" />

                <!-- 미러 모니터 화질 하향 (NFR-2 — 소리 없는 모니터 부하 절감, 기본 꺼짐) -->
                <controls:SettingsCard x:Uid="ReduceMirrorCard">
                    <ToggleSwitch IsOn="{x:Bind ViewModel.ReduceMirrorQuality, Mode=TwoWay}" />
                </controls:SettingsCard>

                <!-- 자막 표시 (FR-20 — 켬=강제 표시/끔=강제 숨김, 기본 꺼짐) -->
                <controls:SettingsCard x:Uid="CaptionsCard">
                    <ToggleSwitch IsOn="{x:Bind ViewModel.CaptionsEnabled, Mode=TwoWay}" />
                </controls:SettingsCard>

                <!-- ═ 소리 ═ -->
                <TextBlock x:Uid="SettingsGroupSound" Style="{StaticResource AppGroupHeaderTextStyle}" />

                <!-- 오디오 출력 모니터 -->
                <controls:SettingsCard x:Uid="AudioCard">
                    <ComboBox
                        MinWidth="150"
                        ItemsSource="{x:Bind ViewModel.AudioOptions}"
                        SelectedIndex="{x:Bind ViewModel.AudioIndex, Mode=TwoWay}" />
                </controls:SettingsCard>

                <!-- 볼륨 (시안 — 값 라벨 + 슬라이더 260) -->
                <controls:SettingsCard x:Uid="VolumeCard">
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <TextBlock
                            Text="{x:Bind FormatVolume(ViewModel.Volume), Mode=OneWay}"
                            MinWidth="32"
                            TextAlignment="Right"
                            FontSize="13"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource AppTextTertiaryBrush}" />
                        <Slider
                            Width="260"
                            Minimum="0"
                            Maximum="100"
                            StepFrequency="1"
                            Value="{x:Bind ViewModel.Volume, Mode=TwoWay}" />
                    </StackPanel>
                </controls:SettingsCard>

                <!-- 음소거 (FR-5 UI 노출) -->
                <controls:SettingsCard x:Uid="MuteCard">
                    <ToggleSwitch IsOn="{x:Bind ViewModel.IsMuted, Mode=TwoWay}" />
                </controls:SettingsCard>

                <!-- ═ 일반 ═ -->
                <TextBlock x:Uid="SettingsGroupGeneral" Style="{StaticResource AppGroupHeaderTextStyle}" />

                <!-- 부팅 자동 시작 (FR-8) -->
                <controls:SettingsCard x:Uid="AutoStartCard">
                    <ToggleSwitch
                        IsOn="{x:Bind ViewModel.AutoStartEnabled, Mode=TwoWay}"
                        IsEnabled="{x:Bind ViewModel.AutoStartToggleAvailable, Mode=OneWay}" />
                </controls:SettingsCard>
                <InfoBar
                    IsOpen="{x:Bind ViewModel.AutoStartStatusVisible, Mode=OneWay}"
                    Message="{x:Bind ViewModel.AutoStartStatusText, Mode=OneWay}"
                    IsClosable="False"
                    Severity="Warning" />

                <!-- 앱 시작 후 자동 재생 (FR-19 — 마지막 항목 재개, 기본 켜짐) -->
                <controls:SettingsCard x:Uid="AutoPlayCard">
                    <ToggleSwitch IsOn="{x:Bind ViewModel.AutoPlayOnLaunch, Mode=TwoWay}" />
                </controls:SettingsCard>

                <!-- 언어 (NFR-4 — 변경 시 셸 재생성) -->
                <controls:SettingsCard x:Uid="LanguageCard">
                    <ComboBox
                        MinWidth="150"
                        ItemsSource="{x:Bind ViewModel.LanguageOptions}"
                        SelectedIndex="{x:Bind ViewModel.LanguageIndex, Mode=TwoWay}" />
                </controls:SettingsCard>

                <!-- 유튜브 계정 (FR-15) -->
                <controls:SettingsCard x:Uid="AccountCard">
                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <TextBlock
                            Text="{x:Bind ViewModel.Account.AccountStatusText, Mode=OneWay}"
                            Style="{StaticResource BodyTextBlockStyle}"
                            FontSize="13"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource AppTextTertiaryBrush}" />
                        <Button
                            Command="{x:Bind ViewModel.Account.AccountActionCommand}"
                            IsEnabled="{x:Bind ViewModel.Account.AccountActionAvailable, Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <!-- 구글 "G" 로고 — 브랜드 공식 4색(앱 디자인 토큰 아님, 변경 금지). 홈 로그인 버튼과 동일 -->
                                <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                    <Grid Width="24" Height="24">
                                        <Path Data="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" Fill="#4285F4" />
                                        <Path Data="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" Fill="#34A853" />
                                        <Path Data="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" Fill="#FBBC05" />
                                        <Path Data="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" Fill="#EA4335" />
                                    </Grid>
                                </Viewbox>
                                <TextBlock
                                    Text="{x:Bind ViewModel.Account.AccountButtonText, Mode=OneWay}"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </controls:SettingsCard>

                <!-- 자동 일시정지 정책 (NFR-1) -->
                <controls:SettingsExpander x:Uid="PauseExpander" IsExpanded="True">
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard x:Uid="PauseFullscreenCard">
                            <ToggleSwitch IsOn="{x:Bind ViewModel.PauseOnFullscreen, Mode=TwoWay}" />
                        </controls:SettingsCard>
                        <controls:SettingsCard x:Uid="PauseBatterySaverCard">
                            <ToggleSwitch IsOn="{x:Bind ViewModel.PauseOnBatterySaver, Mode=TwoWay}" />
                        </controls:SettingsCard>
                        <controls:SettingsCard x:Uid="PauseSessionLockCard">
                            <ToggleSwitch IsOn="{x:Bind ViewModel.PauseOnSessionLock, Mode=TwoWay}" />
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>
            </StackPanel>
            </ContentControl>
        </StackPanel>
    </ScrollViewer>
</Page>
