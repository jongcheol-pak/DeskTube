<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DeskTube.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:ctrls="using:DeskTube.Controls">
    <ScrollViewer Padding="36,24,40,24">
        <StackPanel MaxWidth="1024" Spacing="24" HorizontalAlignment="Stretch">
            <TextBlock x:Uid="SettingsHeader" Style="{StaticResource TitleTextBlockStyle}" />

            <InfoBar
                IsOpen="{x:Bind ViewModel.IsNoticeOpen, Mode=TwoWay}"
                Message="{x:Bind ViewModel.NoticeMessage, Mode=OneWay}"
                Severity="Warning" />

            <!-- StackPanel엔 IsEnabled가 없어 Control 래퍼로 일괄 비활성 (서비스 준비 전) -->
            <ContentControl
                IsEnabled="{x:Bind ViewModel.IsReady, Mode=OneWay}"
                IsTabStop="False"
                HorizontalContentAlignment="Stretch">
            <StackPanel Spacing="4">
                <!-- 재생 모니터 — 시각 카드 클릭 토글, 최소 1개 강제 (restyle T4, 상세 스타일은 T7) -->
                <Border Style="{StaticResource AppCardBorderStyle}" Padding="24,20">
                    <StackPanel Spacing="18">
                        <StackPanel Spacing="3">
                            <TextBlock
                                x:Uid="MonitorsCardTitle"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource AppTextPrimaryBrush}" />
                            <TextBlock
                                x:Uid="MonitorsCardDescription"
                                FontSize="12.5"
                                Foreground="{ThemeResource AppTextTertiaryBrush}" />
                        </StackPanel>
                        <ctrls:MonitorCardsControl Monitors="{x:Bind ViewModel.MonitorPanel.Monitors}" IsLarge="False" />
                    </StackPanel>
                </Border>

                <!-- 오디오 출력 모니터 -->
                <controls:SettingsCard x:Uid="AudioCard">
                    <ComboBox
                        MinWidth="240"
                        ItemsSource="{x:Bind ViewModel.AudioOptions}"
                        SelectedIndex="{x:Bind ViewModel.AudioIndex, Mode=TwoWay}" />
                </controls:SettingsCard>

                <!-- 볼륨 -->
                <controls:SettingsCard x:Uid="VolumeCard">
                    <Slider
                        MinWidth="240"
                        Minimum="0"
                        Maximum="100"
                        StepFrequency="1"
                        Value="{x:Bind ViewModel.Volume, Mode=TwoWay}" />
                </controls:SettingsCard>

                <!-- 음소거 (FR-5 UI 노출 — plan T2/D3. 카드 하나에 컨트롤 2개를 StackPanel로 넣으면
                     ToggleSwitch 상태 문구가 스위치와 겹쳐, 모니터 토글과 동일한 단독 카드 구조로 분리) -->
                <controls:SettingsCard x:Uid="MuteCard">
                    <ToggleSwitch IsOn="{x:Bind ViewModel.IsMuted, Mode=TwoWay}" />
                </controls:SettingsCard>

                <!-- 재생 모드 -->
                <controls:SettingsCard x:Uid="ModeCard">
                    <ComboBox
                        MinWidth="240"
                        ItemsSource="{x:Bind ViewModel.ModeOptions}"
                        SelectedIndex="{x:Bind ViewModel.ModeIndex, Mode=TwoWay}" />
                </controls:SettingsCard>

                <!-- 동영상 크기 모드 (FR-16 — 채움/맞춤/늘리기) -->
                <controls:SettingsCard x:Uid="FitModeCard">
                    <ComboBox
                        MinWidth="240"
                        ItemsSource="{x:Bind ViewModel.FitModeOptions}"
                        SelectedIndex="{x:Bind ViewModel.FitModeIndex, Mode=TwoWay}" />
                </controls:SettingsCard>

                <!-- 화질 스케일 + 유튜브 자동 결정 안내 -->
                <controls:SettingsCard x:Uid="QualityCard">
                    <ComboBox
                        MinWidth="240"
                        ItemsSource="{x:Bind ViewModel.QualityOptions}"
                        SelectedIndex="{x:Bind ViewModel.QualityIndex, Mode=TwoWay}" />
                </controls:SettingsCard>
                <InfoBar
                    x:Uid="QualityNote"
                    IsOpen="True"
                    IsClosable="False"
                    Severity="Informational" />

                <!-- 미러 모니터 화질 하향 (NFR-2 — 소리 없는 모니터 부하 절감, 기본 꺼짐) -->
                <controls:SettingsCard x:Uid="ReduceMirrorCard">
                    <ToggleSwitch IsOn="{x:Bind ViewModel.ReduceMirrorQuality, Mode=TwoWay}" />
                </controls:SettingsCard>

                <!-- 부팅 자동 시작 (FR-8 — T4, T2에서 이연된 카드) -->
                <controls:SettingsCard x:Uid="AutoStartCard">
                    <ToggleSwitch
                        IsOn="{x:Bind ViewModel.AutoStartEnabled, Mode=TwoWay}"
                        IsEnabled="{x:Bind ViewModel.AutoStartToggleAvailable, Mode=OneWay}" />
                </controls:SettingsCard>
                <InfoBar
                    IsOpen="{x:Bind ViewModel.AutoStartStatusVisible, Mode=OneWay}"
                    Message="{x:Bind ViewModel.AutoStartStatusText, Mode=OneWay}"
                    IsClosable="False"
                    Severity="Warning" />

                <!-- 언어 (NFR-4 — T7, T2 이연 카드. 변경 시 셸 재생성) -->
                <controls:SettingsCard x:Uid="LanguageCard">
                    <ComboBox
                        MinWidth="240"
                        ItemsSource="{x:Bind ViewModel.LanguageOptions}"
                        SelectedIndex="{x:Bind ViewModel.LanguageIndex, Mode=TwoWay}" />
                </controls:SettingsCard>

                <!-- 유튜브 계정 (FR-15 — T5) -->
                <controls:SettingsCard x:Uid="AccountCard">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock
                            Text="{x:Bind ViewModel.AccountStatusText, Mode=OneWay}"
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}" />
                        <Button
                            Content="{x:Bind ViewModel.AccountButtonText, Mode=OneWay}"
                            Command="{x:Bind ViewModel.AccountActionCommand}"
                            IsEnabled="{x:Bind ViewModel.AccountActionAvailable, Mode=OneWay}" />
                    </StackPanel>
                </controls:SettingsCard>

                <!-- 자동 일시정지 정책 (NFR-1) -->
                <controls:SettingsExpander x:Uid="PauseExpander" IsExpanded="True">
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard x:Uid="PauseFullscreenCard">
                            <ToggleSwitch IsOn="{x:Bind ViewModel.PauseOnFullscreen, Mode=TwoWay}" />
                        </controls:SettingsCard>
                        <controls:SettingsCard x:Uid="PauseBatterySaverCard">
                            <ToggleSwitch IsOn="{x:Bind ViewModel.PauseOnBatterySaver, Mode=TwoWay}" />
                        </controls:SettingsCard>
                        <controls:SettingsCard x:Uid="PauseSessionLockCard">
                            <ToggleSwitch IsOn="{x:Bind ViewModel.PauseOnSessionLock, Mode=TwoWay}" />
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>
            </StackPanel>
            </ContentControl>
        </StackPanel>
    </ScrollViewer>
</Page>
