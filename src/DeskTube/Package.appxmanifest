<?xml version="1.0" encoding="utf-8"?>
<!-- 임시 identity(DeskTube.Dev) — Store 제출 시 Store 발급 identity로 교체 (plan Known Workarounds) -->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap5="http://schemas.microsoft.com/appx/manifest/uap/windows10/5"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap uap5 rescap">

  <Identity
    Name="DeskTube.Dev"
    Publisher="CN=DeskTubeDev"
    Version="0.1.0.0" />

  <Properties>
    <DisplayName>DeskTube</DisplayName>
    <PublisherDisplayName>DeskTube Dev</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.22000.0" MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Resources>
    <Resource Language="x-generate" />
  </Resources>

  <Applications>
    <Application Id="App" Executable="$targetnametoken$.exe" EntryPoint="$targetentrypoint$">
      <uap:VisualElements
        DisplayName="DeskTube"
        Description="DeskTube"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile Wide310x150Logo="Assets\Wide310x150Logo.png"  Square71x71Logo="Assets\SmallTile.png" Square310x310Logo="Assets\LargeTile.png"/>
        <uap:SplashScreen Image="Assets\SplashScreen.png" />
      </uap:VisualElements>
      <Extensions>
        <!-- 부팅 자동 시작 (PRD FR-8) — 기본 꺼짐, 설정 토글로 활성화 (plan T4).
             표시명은 슬래시 3개형 ms-resource 필수 (AGENTS 다국어 규칙 4 — root 명시형은 resolve 실패).
             Executable은 리터럴 필수 — $targetnametoken$ 토큰은 Extension 요소에서 치환되지 않음 (MakeAppx 검증 오류) -->
        <uap5:Extension Category="windows.startupTask" Executable="DeskTube.exe" EntryPoint="Windows.FullTrustApplication">
          <uap5:StartupTask
            TaskId="DeskTubeStartupTask"
            Enabled="false"
            DisplayName="ms-resource:///Resources/StartupTaskDisplayName" />
        </uap5:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
