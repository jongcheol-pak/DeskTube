<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DeskTube.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrls="using:DeskTube.Controls"
    xmlns:vm="using:DeskTube.ViewModels">
    <!-- 시안 홈: 제목/부제 → URL 입력+재생 → 재생 중 pill → 모니터 카드 → (하단) 빠른 재생.
         시안이 overflow:auto + 빠른 재생 하단 정렬(margin-top:auto)이라 ScrollViewer 안 Grid의
         MinHeight를 뷰포트에 맞춰(코드비하인드) 둘 다 재현한다. -->
    <ScrollViewer x:Name="Root" SizeChanged="OnRootSizeChanged">
        <Grid x:Name="Layout" Padding="{StaticResource AppPagePadding}" RowSpacing="36">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 제목 + 부제 (시안 30px/14px) + 우측 로그인 상태 (FR-15) -->
            <Grid Grid.Row="0" ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="8">
                    <TextBlock
                        x:Uid="HomeHeader"
                        FontSize="30"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource AppTextStrongBrush}" />
                    <TextBlock
                        x:Uid="HomeSubtitle"
                        FontSize="14"
                        Foreground="{ThemeResource AppTextSecondaryBrush}" />
                </StackPanel>
                <!-- 유튜브 계정 상태 + 로그인/로그아웃 (공용 계정 패널 — 설정 카드와 동일 바인딩) -->
                <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Top">
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="14"
                        HorizontalAlignment="Right">
                        <TextBlock
                            Text="{x:Bind ViewModel.Account.AccountStatusText, Mode=OneWay}"
                            Style="{StaticResource BodyTextBlockStyle}"
                            FontSize="13"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource AppTextTertiaryBrush}" />
                        <Button
                            Command="{x:Bind ViewModel.Account.AccountActionCommand}"
                            IsEnabled="{x:Bind ViewModel.Account.AccountActionAvailable, Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <!-- 구글 "G" 로고 — 브랜드 공식 4색(앱 디자인 토큰 아님, 변경 금지).
                                     path는 Wikimedia Commons 공식 SVG(viewBox 24) 원본 그대로 -->
                                <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                    <Grid Width="24" Height="24">
                                        <Path Data="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" Fill="#4285F4" />
                                        <Path Data="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" Fill="#34A853" />
                                        <Path Data="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" Fill="#FBBC05" />
                                        <Path Data="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" Fill="#EA4335" />
                                    </Grid>
                                </Viewbox>
                                <TextBlock
                                    Text="{x:Bind ViewModel.Account.AccountButtonText, Mode=OneWay}"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <!-- 프리미엄 안내 (FR-15 — 로그인 시 광고 미표시) -->
                    <TextBlock
                        x:Uid="HomePremiumHint"
                        FontSize="12"
                        MaxWidth="340"
                        TextWrapping="Wrap"
                        TextAlignment="Right"
                        HorizontalAlignment="Right"
                        Foreground="{ThemeResource AppTextTertiaryBrush}" />
                </StackPanel>
            </Grid>

            <!-- URL 입력 + 재생 버튼 (시안 h48, max 860, gap 12) -->
            <Grid Grid.Row="1" MaxWidth="860" HorizontalAlignment="Left" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!-- WinUI TextBox 템플릿은 VerticalContentAlignment를 무시하므로 세로 패딩으로 중앙 정렬 -->
                <TextBox
                    x:Uid="HomeUrlBox"
                    x:Name="UrlBox"
                    Grid.Column="0"
                    Height="48"
                    MinWidth="480"
                    Padding="18,13"
                    Background="{ThemeResource AppInputBackgroundBrush}"
                    BorderBrush="{ThemeResource AppInputBorderBrush}"
                    CornerRadius="{StaticResource AppCardCornerRadius}"
                    Text="{x:Bind ViewModel.Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    KeyDown="OnUrlBoxKeyDown" />
                <Button
                    Grid.Column="1"
                    Height="48"
                    Padding="26,0"
                    Style="{StaticResource AccentButtonStyle}"
                    CornerRadius="{StaticResource AppCardCornerRadius}"
                    Command="{x:Bind ViewModel.PlayCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE768;" FontSize="14" />
                        <TextBlock x:Uid="HomePlayLabel" FontSize="14" FontWeight="SemiBold" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- 재생 중 pill (시안 — 코럴 dot + 라벨 + 정지 버튼, 재생 중에만) -->
            <Border
                Grid.Row="2"
                Visibility="{x:Bind ViewModel.IsPlaying, Mode=OneWay}"
                Background="{ThemeResource AppTintBackgroundBrush}"
                BorderBrush="{ThemeResource AppTintBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource AppPillCornerRadius}"
                Padding="18,8,8,8"
                HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{ThemeResource AppAccentBrush}" VerticalAlignment="Center" />
                    <TextBlock
                        Text="{x:Bind ViewModel.PlayingLabel, Mode=OneWay}"
                        FontSize="13"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource AppTintTextBrush}" />
                    <Button
                        Padding="14,5"
                        Background="{ThemeResource AppTintButtonBackgroundBrush}"
                        BorderThickness="0"
                        CornerRadius="{StaticResource AppStopButtonCornerRadius}"
                        Command="{x:Bind ViewModel.StopCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE71A;" FontSize="11" Foreground="{ThemeResource AppTintButtonTextBrush}" />
                            <TextBlock
                                x:Uid="HomeStopLabel"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource AppTintButtonTextBrush}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- 재생 모니터 (시안 — 대형 카드, 클릭 토글) -->
            <StackPanel Grid.Row="3" Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock
                        x:Uid="HomeMonitorsTitle"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource AppTextPrimaryBrush}" />
                    <TextBlock
                        x:Uid="HomeMonitorsHint"
                        FontSize="13"
                        VerticalAlignment="Bottom"
                        Foreground="{ThemeResource AppTextTertiaryBrush}" />
                </StackPanel>
                <ctrls:MonitorCardsControl
                    Monitors="{x:Bind ViewModel.MonitorPanel.Monitors}"
                    IsLarge="True"
                    MuteToggleCommand="{x:Bind ViewModel.MonitorPanel.ToggleMuteCommand}" />
            </StackPanel>

            <!-- 빠른 재생 칩 (시안 — 페이지 하단 정렬, 리스트 없으면 섹션 숨김) -->
            <StackPanel
                Grid.Row="5"
                Spacing="12"
                Visibility="{x:Bind ViewModel.HasChips, Mode=OneWay}">
                <TextBlock
                    x:Uid="HomeQuickPlayTitle"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource AppTextPrimaryBrush}" />
                <ItemsControl ItemsSource="{x:Bind ViewModel.QuickChips}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VariableSizedWrapGrid Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:QuickChip">
                            <Button
                                Style="{StaticResource AppChipButtonStyle}"
                                Margin="0,0,12,12"
                                Click="OnChipClick">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE8FD;" FontSize="13" />
                                    <TextBlock Text="{x:Bind Name}" FontSize="13" />
                                    <TextBlock
                                        Text="{x:Bind CountText}"
                                        FontSize="13"
                                        Foreground="{ThemeResource AppTextTertiaryBrush}" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
