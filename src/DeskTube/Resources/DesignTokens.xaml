<?xml version="1.0" encoding="utf-8"?>
<!--
  디자인 토큰 (plan 2026-07-16-design-1a-restyle T2, AGENTS 디자인 규칙 2·5).
  값의 정본은 plan의 "시각 요소 분해"·D3 표 — 화면은 이 토큰 키만 참조한다 (하드코딩 금지).
  구조: D3 표 키명 그대로의 Color 리소스 + 대응 Brush (plan T2 Design ② — acceptance의
  "D3 전 키 존재" 기계 검증이 이 Color 키들을 대조한다). 화면은 Brush 키를 소비한다.
  앱은 다크 고정(App.xaml RequestedTheme="Dark")이라 Light 사전은 두지 않고,
  시스템 고대비 모드만 HighContrast 사전으로 대응한다 (plan D11).
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <!-- D3 색 토큰 (시안 원값) -->
            <Color x:Key="AppRootBackgroundColor">#1A1A1C</Color>
            <Color x:Key="AppContentBackgroundColor">#202023</Color>
            <Color x:Key="AppContentBorderColor">#2C2C30</Color>
            <Color x:Key="AppCardBackgroundColor">#242427</Color>
            <Color x:Key="AppCardBorderColor">#2F2F34</Color>
            <Color x:Key="AppInputBackgroundColor">#2A2A2E</Color>
            <Color x:Key="AppInputBorderColor">#3A3A40</Color>
            <Color x:Key="AppInputBottomLineColor">#55555C</Color>
            <Color x:Key="AppComboBackgroundColor">#2E2E32</Color>
            <Color x:Key="AppComboBorderColor">#3D3D43</Color>
            <Color x:Key="AppHoverBackgroundColor">#28282C</Color>
            <Color x:Key="AppActiveBackgroundColor">#2A2A2E</Color>
            <Color x:Key="AppDividerColor">#2C2C30</Color>
            <Color x:Key="AppDashedBorderColor">#4A4A50</Color>
            <Color x:Key="AppTextPrimaryColor">#E8E8EA</Color>
            <Color x:Key="AppTextStrongColor">#FFFFFF</Color>
            <Color x:Key="AppTextSecondaryColor">#9A9AA0</Color>
            <Color x:Key="AppTextTertiaryColor">#8A8A90</Color>
            <Color x:Key="AppTextNavColor">#B8B8BE</Color>
            <Color x:Key="AppChipTextColor">#D8D8DC</Color>
            <Color x:Key="AppAccentColor">#F25C54</Color>
            <Color x:Key="AppAccentHoverColor">#FF6F66</Color>
            <Color x:Key="AppAccentSoftHoverColor">#FF8A82</Color>
            <Color x:Key="AppTintBackgroundColor">#2A2326</Color>
            <Color x:Key="AppTintBorderColor">#4A3338</Color>
            <Color x:Key="AppTintTextColor">#E8C9C5</Color>
            <Color x:Key="AppTintBodyColor">#C9B4B1</Color>
            <Color x:Key="AppTintButtonBackgroundColor">#3A2A2C</Color>
            <Color x:Key="AppTintButtonTextColor">#F2A49F</Color>
            <Color x:Key="AppMonitorNumberSelectedColor">#F2A49F</Color>
            <Color x:Key="AppMonitorNumberColor">#6A6A70</Color>
            <Color x:Key="AppMonitorSubSelectedColor">#C9948F</Color>
            <Color x:Key="AppMonitorSubColor">#7A7A80</Color>
            <Color x:Key="AppMonitorBorderColor">#3A3A40</Color>
            <Color x:Key="AppMonitorStandColor">#3A3A40</Color>
            <!-- 소리 배지 (2026-07-17 배지 리스타일 — 코럴 배경 위 진한 글자, 음소거는 저채도 회색) -->
            <Color x:Key="AppBadgeForegroundColor">#1A1A1C</Color>
            <Color x:Key="AppBadgeMutedBackgroundColor">#3A3A40</Color>
            <Color x:Key="AppBadgeMutedForegroundColor">#B8B8BE</Color>

            <!-- 대응 브러시 (화면 소비용) — 배경·면 -->
            <SolidColorBrush x:Key="AppRootBackgroundBrush" Color="{StaticResource AppRootBackgroundColor}" />
            <SolidColorBrush x:Key="AppContentBackgroundBrush" Color="{StaticResource AppContentBackgroundColor}" />
            <SolidColorBrush x:Key="AppContentBorderBrush" Color="{StaticResource AppContentBorderColor}" />
            <SolidColorBrush x:Key="AppCardBackgroundBrush" Color="{StaticResource AppCardBackgroundColor}" />
            <SolidColorBrush x:Key="AppCardBorderBrush" Color="{StaticResource AppCardBorderColor}" />
            <SolidColorBrush x:Key="AppInputBackgroundBrush" Color="{StaticResource AppInputBackgroundColor}" />
            <SolidColorBrush x:Key="AppInputBorderBrush" Color="{StaticResource AppInputBorderColor}" />
            <SolidColorBrush x:Key="AppInputBottomLineBrush" Color="{StaticResource AppInputBottomLineColor}" />
            <SolidColorBrush x:Key="AppComboBackgroundBrush" Color="{StaticResource AppComboBackgroundColor}" />
            <SolidColorBrush x:Key="AppComboBorderBrush" Color="{StaticResource AppComboBorderColor}" />
            <SolidColorBrush x:Key="AppHoverBackgroundBrush" Color="{StaticResource AppHoverBackgroundColor}" />
            <SolidColorBrush x:Key="AppActiveBackgroundBrush" Color="{StaticResource AppActiveBackgroundColor}" />
            <SolidColorBrush x:Key="AppDividerBrush" Color="{StaticResource AppDividerColor}" />
            <SolidColorBrush x:Key="AppDashedBorderBrush" Color="{StaticResource AppDashedBorderColor}" />

            <!-- 대응 브러시 — 텍스트 -->
            <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="{StaticResource AppTextPrimaryColor}" />
            <SolidColorBrush x:Key="AppTextStrongBrush" Color="{StaticResource AppTextStrongColor}" />
            <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="{StaticResource AppTextSecondaryColor}" />
            <SolidColorBrush x:Key="AppTextTertiaryBrush" Color="{StaticResource AppTextTertiaryColor}" />
            <SolidColorBrush x:Key="AppTextNavBrush" Color="{StaticResource AppTextNavColor}" />
            <SolidColorBrush x:Key="AppChipTextBrush" Color="{StaticResource AppChipTextColor}" />

            <!-- 대응 브러시 — 포인트(코럴)·틴트 면 -->
            <SolidColorBrush x:Key="AppAccentBrush" Color="{StaticResource AppAccentColor}" />
            <SolidColorBrush x:Key="AppAccentHoverBrush" Color="{StaticResource AppAccentHoverColor}" />
            <SolidColorBrush x:Key="AppAccentSoftHoverBrush" Color="{StaticResource AppAccentSoftHoverColor}" />
            <SolidColorBrush x:Key="AppTintBackgroundBrush" Color="{StaticResource AppTintBackgroundColor}" />
            <SolidColorBrush x:Key="AppTintBorderBrush" Color="{StaticResource AppTintBorderColor}" />
            <SolidColorBrush x:Key="AppTintTextBrush" Color="{StaticResource AppTintTextColor}" />
            <SolidColorBrush x:Key="AppTintBodyBrush" Color="{StaticResource AppTintBodyColor}" />
            <SolidColorBrush x:Key="AppTintButtonBackgroundBrush" Color="{StaticResource AppTintButtonBackgroundColor}" />
            <SolidColorBrush x:Key="AppTintButtonTextBrush" Color="{StaticResource AppTintButtonTextColor}" />

            <!-- 대응 브러시 — 모니터 카드 -->
            <SolidColorBrush x:Key="AppMonitorNumberSelectedBrush" Color="{StaticResource AppMonitorNumberSelectedColor}" />
            <SolidColorBrush x:Key="AppMonitorNumberBrush" Color="{StaticResource AppMonitorNumberColor}" />
            <SolidColorBrush x:Key="AppMonitorSubSelectedBrush" Color="{StaticResource AppMonitorSubSelectedColor}" />
            <SolidColorBrush x:Key="AppMonitorSubBrush" Color="{StaticResource AppMonitorSubColor}" />
            <SolidColorBrush x:Key="AppMonitorBorderBrush" Color="{StaticResource AppMonitorBorderColor}" />
            <SolidColorBrush x:Key="AppMonitorStandBrush" Color="{StaticResource AppMonitorStandColor}" />
            <SolidColorBrush x:Key="AppBadgeForegroundBrush" Color="{StaticResource AppBadgeForegroundColor}" />
            <SolidColorBrush x:Key="AppBadgeMutedBackgroundBrush" Color="{StaticResource AppBadgeMutedBackgroundColor}" />
            <SolidColorBrush x:Key="AppBadgeMutedForegroundBrush" Color="{StaticResource AppBadgeMutedForegroundColor}" />

            <!-- 그라디언트 (D3: AppMonitorSelectedBackground 180° / AppThumbPlaceholderBackground 135°) -->
            <LinearGradientBrush x:Key="AppMonitorSelectedBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Offset="0" Color="#3A2726" />
                <GradientStop Offset="1" Color="#2A1E1D" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="AppThumbPlaceholderBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#4A3038" />
                <GradientStop Offset="1" Color="#25191D" />
            </LinearGradientBrush>

            <!-- NavigationView lightweight 오버라이드 (시안 사이드바 — plan T3, 미적용 키는 HUMAN-VERIFY로 검출) -->
            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="Transparent" />
            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="Transparent" />
            <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
            <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent" />
            <SolidColorBrush x:Key="NavigationViewItemForeground" Color="{StaticResource AppTextNavColor}" />
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelected" Color="{StaticResource AppTextStrongColor}" />
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelected" Color="{StaticResource AppActiveBackgroundColor}" />
            <SolidColorBrush x:Key="NavigationViewItemBackgroundPointerOver" Color="{StaticResource AppHoverBackgroundColor}" />

            <!-- ListView lightweight 오버라이드 (시안 행 hover·활성 — plan T6) -->
            <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="{StaticResource AppHoverBackgroundColor}" />
            <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="{StaticResource AppActiveBackgroundColor}" />
            <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="{StaticResource AppActiveBackgroundColor}" />

            <!-- SettingsCard(CommunityToolkit) lightweight 오버라이드 (시안 설정 카드 — plan T7,
                 미적용 키는 HUMAN-VERIFY로 검출) -->
            <SolidColorBrush x:Key="SettingsCardBackground" Color="{StaticResource AppCardBackgroundColor}" />
            <SolidColorBrush x:Key="SettingsCardBorderBrush" Color="{StaticResource AppCardBorderColor}" />
        </ResourceDictionary>

        <!-- 고대비 — 시스템 HC 색으로 매핑 (시각 정합 정밀 조정은 Deferred, plan D11).
             HC의 시스템 색은 리터럴 별칭이 불가능해 Color 토큰 없이 Brush만 재정의한다. -->
        <ResourceDictionary x:Key="HighContrast">
            <SolidColorBrush x:Key="AppRootBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="AppContentBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="AppContentBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="AppCardBackgroundBrush" Color="{ThemeResource SystemColorButtonFaceColor}" />
            <SolidColorBrush x:Key="AppCardBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="AppInputBackgroundBrush" Color="{ThemeResource SystemColorButtonFaceColor}" />
            <SolidColorBrush x:Key="AppInputBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="AppInputBottomLineBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="AppComboBackgroundBrush" Color="{ThemeResource SystemColorButtonFaceColor}" />
            <SolidColorBrush x:Key="AppComboBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="AppHoverBackgroundBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="AppActiveBackgroundBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="AppDividerBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="AppDashedBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="AppTextStrongBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="AppTextTertiaryBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="AppTextNavBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="AppChipTextBrush" Color="{ThemeResource SystemColorButtonTextColor}" />
            <SolidColorBrush x:Key="AppAccentBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="AppAccentHoverBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="AppAccentSoftHoverBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="AppTintBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="AppTintBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="AppTintTextBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="AppTintBodyBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="AppTintButtonBackgroundBrush" Color="{ThemeResource SystemColorButtonFaceColor}" />
            <SolidColorBrush x:Key="AppTintButtonTextBrush" Color="{ThemeResource SystemColorButtonTextColor}" />
            <SolidColorBrush x:Key="AppMonitorSelectedBackgroundBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="AppMonitorNumberSelectedBrush" Color="{ThemeResource SystemColorHighlightTextColor}" />
            <SolidColorBrush x:Key="AppMonitorNumberBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="AppMonitorSubSelectedBrush" Color="{ThemeResource SystemColorHighlightTextColor}" />
            <SolidColorBrush x:Key="AppMonitorSubBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="AppMonitorBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="AppMonitorStandBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <!-- 소리 배지 — 배경이 Highlight(AppAccentBrush)이므로 글자는 HighlightText, 음소거는 버튼 색 계열 -->
            <SolidColorBrush x:Key="AppBadgeForegroundBrush" Color="{ThemeResource SystemColorHighlightTextColor}" />
            <SolidColorBrush x:Key="AppBadgeMutedBackgroundBrush" Color="{ThemeResource SystemColorButtonFaceColor}" />
            <SolidColorBrush x:Key="AppBadgeMutedForegroundBrush" Color="{ThemeResource SystemColorButtonTextColor}" />
            <SolidColorBrush x:Key="AppThumbPlaceholderBackgroundBrush" Color="{ThemeResource SystemColorButtonFaceColor}" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- 치수 (테마 무관) — 시안 원값 -->
    <x:Double x:Key="AppTitleBarHeight">44</x:Double>
    <x:Double x:Key="AppSidebarWidth">220</x:Double>
    <CornerRadius x:Key="AppContentCornerRadius">10,0,0,0</CornerRadius>
    <CornerRadius x:Key="AppCardCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="AppControlCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="AppIconCornerRadius">5</CornerRadius>
    <CornerRadius x:Key="AppMonitorCardCornerRadius">10</CornerRadius>
    <CornerRadius x:Key="AppMonitorStandCornerRadius">3</CornerRadius>
    <CornerRadius x:Key="AppBadgeCornerRadius">4</CornerRadius>
    <CornerRadius x:Key="AppPillCornerRadius">20</CornerRadius>
    <CornerRadius x:Key="AppStopButtonCornerRadius">14</CornerRadius>
    <CornerRadius x:Key="AppCircleButtonCornerRadius">17</CornerRadius>
    <CornerRadius x:Key="AppLargeIconCornerRadius">12</CornerRadius>
    <Thickness x:Key="AppPagePadding">56,44</Thickness>
    <!-- 콘텐츠 고정 폭 1000 — 홈·설정·정보 공통, 창 폭에 따라 가운데 정렬·좁으면 가로 스크롤 (사용자 확정).
         플레이리스트는 분할 레이아웃이라 이 값을 최소 폭으로만 사용 -->
    <x:Double x:Key="AppPageContentWidth">1000</x:Double>
    <!-- 홈 전용 — Layout Grid가 페이지 패딩(AppPagePadding 좌우 56×2)을 소유하므로 콘텐츠 1000 + 112 -->
    <x:Double x:Key="AppPageFrameWidth">1112</x:Double>

    <!-- 공용 스타일 — 시안 반복 요소 (plan T2 Design ②) -->

    <!-- 외곽선 액션 버튼 (셔플듣기·추가 등 — 시안: 테두리 #3A3A40, radius 8, hover 코럴 테두리) -->
    <Style x:Key="AppPillButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppInputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource AppCardCornerRadius}" />
        <Setter Property="Padding" Value="18,9" />
        <Setter Property="Foreground" Value="{ThemeResource AppChipTextBrush}" />
    </Style>

    <!-- 빠른 재생 칩 (시안: 배경 #2A2A2E, 테두리 #3A3A40, radius 8, padding 16,10) -->
    <Style x:Key="AppChipButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background" Value="{ThemeResource AppInputBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppInputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource AppCardCornerRadius}" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="Foreground" Value="{ThemeResource AppChipTextBrush}" />
    </Style>

    <!-- 점선 버튼 (새 플레이리스트 — 시안: dashed 테두리는 XAML 미지원이라 전용 테두리 색 실선으로 근사,
         hover 코럴 전환은 소비측 포인터 이벤트가 처리 — PlaylistsPage.OnDashedButtonPointer*) -->
    <Style x:Key="AppDashedButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppDashedBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource AppCardCornerRadius}" />
        <Setter Property="Padding" Value="14,11" />
        <Setter Property="Foreground" Value="{ThemeResource AppTextNavBrush}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <!-- 카드 컨테이너 (설정·정보 카드 — 시안: #242427 면, #2F2F34 테두리, radius 8) -->
    <Style x:Key="AppCardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource AppCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource AppCardCornerRadius}" />
    </Style>

    <!-- 설정 그룹 헤더 (시안: 12.5px w700 letter-spacing 0.06em #9A9AA0) -->
    <Style x:Key="AppGroupHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12.5" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="CharacterSpacing" Value="60" />
        <Setter Property="Foreground" Value="{ThemeResource AppTextSecondaryBrush}" />
        <Setter Property="Margin" Value="4,16,4,2" />
    </Style>
</ResourceDictionary>
